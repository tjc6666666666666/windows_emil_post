# 应用配置
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=jwt-secret-key-change-in-production

# 邮件服务器域名（用户注册后自动获得 username@MAIL_DOMAIN 邮箱）
MAIL_DOMAIN=453627.xyz

# 数据库配置（PostgreSQL）
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/email_server

# 或者使用SQLite（默认）
DATABASE_URL=sqlite+aiosqlite:///./email_server.db

# SMTP服务器配置（用于接收邮件）
SMTP_HOST=0.0.0.0
SMTP_PORT=25

# IMAP服务器配置
IMAP_HOST=localhost
IMAP_PORT=143

# DNS解析服务器（用于发送邮件时解析MX记录）
DNS_SERVERS=["8.8.8.8", "114.114.114.114"]
